# ─── VELYON LEGAL COMMAND CENTER — .gitignore ─────────────────────────────

# Watcher runtime files (prevent self-triggering loops)
inventory_watcher.log
files_registry.json

# Nested git repositories (CRITICAL — prevents git add -A exit code 128)
_github_los_romeros_repo/
_github_*/
*/.git/

# Antigravity brain/session files (managed separately, not committed to repo)
.gemini/
antigravity/brain/

# VS Code
.vscode/
*.code-workspace

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Node
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.temp
~$*

# Temp folder init placeholders
.folder_init/
**/.keep
